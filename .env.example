# Скопируйте этот файл в .env и заполните своими значениями.
# Файл .env в репозиторий не попадает (см. .gitignore).

# Токен бота, полученный у @BotFather в Telegram. Обязательный параметр.
BOT_TOKEN=123456789:AaBbCcDdEeFfGgHhIiJjKkLlMmNnOoPpQq

# Языки распознавания EasyOCR через запятую. По умолчанию: ru,en
OCR_LANGUAGES=ru,en

# Использовать ли GPU (CUDA) для EasyOCR. Для большинства ноутбуков — false.
USE_GPU=false

# Максимально допустимый размер входящего файла в мегабайтах.
MAX_FILE_SIZE_MB=20

# Сохранять ли загруженные пользователями изображения на диск (data/uploads).
# По умолчанию файлы удаляются после распознавания.
KEEP_UPLOADS=false

# --- Модель OCR ---
# easyocr — стандартные веса EasyOCR (по умолчанию)
# finetuned — кастомные веса, дообученные локально (см. ocr-training/)
OCR_MODEL=easyocr

# Имя кастомной recog-сети (для OCR_MODEL=finetuned).
# Должны существовать файлы:
#   data/models/custom/<name>.pth
#   data/models/user_network/<name>.yaml
#   data/models/user_network/<name>.py
CUSTOM_RECOG_NETWORK=

# Переопределение путей (опционально).
# CUSTOM_MODELS_DIR=data/models/custom
# CUSTOM_USER_NETWORK_DIR=data/models/user_network

# --- Предобработка ---
# Коррекция небольшого наклона текста (±15°).
USE_DESKEW=true

# Коррекция ориентации (поворот 0/90/180/270). Дороже в 4 раза,
# по умолчанию выключено.
USE_ORIENTATION_CORRECTION=false
